DISCORD_TOKEN=wklej_tutaj_token_bota
# MongoDB connection string. Wymagane — bez tego bot nie wystartuje.
# Linux self-hosted (ten sam host co bot, default port):
#   MONGO_URI=mongodb://127.0.0.1:27017/discordbot
# Docker (lokalnie):  docker run -d -p 27017:27017 --name mongo mongo:7
# Z auth (user/pass):  mongodb://user:pass@127.0.0.1:27017/discordbot?authSource=admin
# MongoDB Atlas:      mongodb+srv://user:pass@cluster.mongodb.net/discordbot
# Po pierwszym starcie z legacy `data/players/*.json` — migracja jest one-shot,
# stary folder rename'uje się na `data/players.migrated-<ts>` (safety net).
MONGO_URI=mongodb://127.0.0.1:27017/discordbot
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_MODEL_MED=medgemma:4b
TMDB_API_KEY=wklej_tutaj_api_key_z_themoviedb_org
THREAD_TTL_MIN=60
AMBUSH_CHECK_INTERVAL_MS=300000
AMBUSH_CHANCE=0.25
# Kanał dla world-boss event (10/13/16/19/22 codziennie). Bez tego loop tick'uje no-op.
WORLD_BOSS_CHANNEL_ID=
# Kanał dla arena PvP (codziennie 18:00). Fallback do WORLD_BOSS_CHANNEL_ID.
ARENA_CHANNEL_ID=
